# Environment Variables for Development
# Copy this file to .env.local and fill in your actual values

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-adsense-id

# Push Notifications (Web Push)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Application Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional)
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# API Revalidation Secret (used by /api/revalidate and /api/revalidate-sitemap)
REVALIDATE_SECRET=your-random-secret-token-here

# GitHub Copilot API (used by scripts/enrich-song-metadata.ts for GPT-4o enrichment)
# Use a GitHub Personal Access Token with Copilot access, or a Copilot API key
GITHUB_TOKEN=your-github-personal-access-token
# COPILOT_API_KEY=your-copilot-api-key  # alternative to GITHUB_TOKEN
# Google Cloud Storage (Optional - for OG image hosting)
# If not set, images will be saved locally to public/og-images/
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-project-id
# For local development: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./scripts/gcs/gcs-service-account.json
# For CI/GitHub Actions: base64-encoded service account JSON (use GitHub Secrets)
# GCS_SERVICE_ACCOUNT_KEY=base64-encoded-json

# Vercel System Environment Variables (Automatically set by Vercel)
# VERCEL_PROJECT_PRODUCTION_URL - Production domain name (e.g., www.tsonglyrics.com)
# This is automatically set by Vercel in production deployments
# For local development, the app will default to http://localhost:3000
